# Sniffy Configuration

# GitHub API Token (optional but recommended for higher rate limits)
# Supports both classic and fine-grained personal access tokens
# If invalid or expired, the worker will automatically fall back to unauthenticated mode
GITHUB_TOKEN=

# Worker identification
WORKER_ID=

# Database configuration
DATABASE_PATH=./data/sniffy.db

# Scanning configuration
CONFIDENCE_THRESHOLD=25
MAX_CONCURRENT_CLONES=10
MAX_REPO_SIZE_GB=1
DISK_LIMIT_GB=10
ACTIVE_SCAN_WINDOW_HOURS=1       # How far back the Active track looks for recently updated repos
FRESH_TRACK_SLEEP_SECONDS=30     # How long the Fresh track sleeps when no new repos found

# Notification configuration
NOTIFIER_TYPES=email
NOTIFICATION_RATE_LIMIT=10

# Email notifier configuration
EMAIL_CONFIDENCE_THRESHOLD=25
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Future notifier configurations (examples)
# SLACK_CONFIDENCE_THRESHOLD=30
# SLACK_WEBHOOK_URL=
# WEBHOOK_CONFIDENCE_THRESHOLD=20
# WEBHOOK_URL=
